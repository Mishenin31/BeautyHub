<UserControl x:Class="BeautyHub.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Пользователи системы" Style="{StaticResource Header}"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="10" Padding="4" Margin="0,0,16,0">
                <DataGrid x:Name="Grid">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="140"/>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding RoleDisplay}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Добавить пользователя" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="ФИО" Style="{StaticResource Label}"/>
                    <TextBox x:Name="NameBox"/>
                    <TextBlock Text="Логин" Style="{StaticResource Label}"/>
                    <TextBox x:Name="LoginBox"/>
                    <TextBlock Text="Пароль" Style="{StaticResource Label}"/>
                    <TextBox x:Name="PassBox"/>
                    <TextBlock Text="Роль" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="RoleBox"/>
                    <Button Content="Добавить" Margin="0,20,0,0" Click="Add_Click"/>
                    <Button Content="Удалить выбранного" Background="#9E9E9E" Click="Delete_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
