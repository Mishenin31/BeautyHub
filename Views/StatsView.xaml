<UserControl x:Class="BeautyHub.Views.StatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Статистика" Style="{StaticResource Header}"/>

        <WrapPanel>
            <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="24" Margin="0,0,16,16" Width="220">
                <StackPanel>
                    <TextBlock Text="Всего записей" FontSize="14" Foreground="#888"/>
                    <TextBlock x:Name="TotalAppts" FontSize="34" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="24" Margin="0,0,16,16" Width="220">
                <StackPanel>
                    <TextBlock Text="Завершено" FontSize="14" Foreground="#888"/>
                    <TextBlock x:Name="Completed" FontSize="34" FontWeight="Bold" Foreground="#43A047"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="24" Margin="0,0,16,16" Width="220">
                <StackPanel>
                    <TextBlock Text="Выручка (завершённые)" FontSize="14" Foreground="#888"/>
                    <TextBlock x:Name="Revenue" FontSize="34" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="24" Margin="0,0,16,16" Width="220">
                <StackPanel>
                    <TextBlock Text="Клиентов / Мастеров" FontSize="14" Foreground="#888"/>
                    <TextBlock x:Name="People" FontSize="34" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="20" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock Text="Популярность услуг" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                <ItemsControl x:Name="ServiceStats">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Height="18" Maximum="{Binding Max}" Value="{Binding Count}"
                                             Foreground="{StaticResource PrimaryLightBrush}" Background="#F0E0E8"/>
                                <TextBlock Grid.Column="2" Text="{Binding Count}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
