<UserControl x:Class="BeautyHub.Views.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderText" Text="Услуги салона" Style="{StaticResource Header}"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300" x:Name="FormColumn"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="10" Padding="4" Margin="0,0,16,0">
                <DataGrid x:Name="Grid">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="160"/>
                        <DataGridTextColumn Header="Длит. (мин)" Binding="{Binding DurationMinutes}" Width="100"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N0} ₽}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" x:Name="FormPanel" Background="{StaticResource CardBrush}" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Добавить услугу" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Название" Style="{StaticResource Label}"/>
                    <TextBox x:Name="NameBox"/>
                    <TextBlock Text="Категория" Style="{StaticResource Label}"/>
                    <TextBox x:Name="CategoryBox"/>
                    <TextBlock Text="Длительность (мин)" Style="{StaticResource Label}"/>
                    <TextBox x:Name="DurationBox"/>
                    <TextBlock Text="Цена (₽)" Style="{StaticResource Label}"/>
                    <TextBox x:Name="PriceBox"/>
                    <Button Content="Добавить" Margin="0,20,0,0" Click="Add_Click"/>
                    <Button Content="Удалить выбранную" Background="#9E9E9E" Click="Delete_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
